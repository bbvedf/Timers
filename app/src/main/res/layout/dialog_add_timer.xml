<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Name input field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timer Name"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/timer_name_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter timer name (optional)"
            android:inputType="text"
            android:layout_marginBottom="16dp"/>

        <!-- Time display preview -->
        <TextView
            android:id="@+id/timer_display_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="00h 00m 00s"
            android:layout_marginBottom="16dp"/>

        <TableLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:stretchColumns="1">

            <!-- Hours row -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hours"
                    android:paddingEnd="16dp"
                    android:layout_gravity="center_vertical"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/hours_down_button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_time_decrease"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                    <EditText
                        android:id="@+id/hours_value"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="2"
                        android:selectAllOnFocus="true"
                        android:text="00"
                        android:background="@android:color/transparent"/>
                    <ImageButton
                        android:id="@+id/hours_up_button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_time_increase"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>
            </TableRow>

            <!-- Minutes row -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minutes"
                    android:paddingEnd="16dp"
                    android:layout_gravity="center_vertical"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/minutes_down_button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_time_decrease"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                    <EditText
                        android:id="@+id/minutes_value"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="2"
                        android:selectAllOnFocus="true"
                        android:text="00"
                        android:background="@android:color/transparent"/>
                    <ImageButton
                        android:id="@+id/minutes_up_button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_time_increase"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>
            </TableRow>

            <!-- Seconds row -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seconds"
                    android:paddingEnd="16dp"
                    android:layout_gravity="center_vertical"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/seconds_down_button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_time_decrease"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                    <EditText
                        android:id="@+id/seconds_value"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="2"
                        android:selectAllOnFocus="true"
                        android:text="00"
                        android:background="@android:color/transparent"/>
                    <ImageButton
                        android:id="@+id/seconds_up_button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_time_increase"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>
            </TableRow>

        </TableLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
